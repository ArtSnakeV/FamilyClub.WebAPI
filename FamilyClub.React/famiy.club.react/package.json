  "private": true,
  "scripts": {
    "dev": "cross-env NODE_EXTRA_CA_CERTS=%USERPROFILE%\\.aspnet\\https\\dev-cert.pem next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "update-api": "npx openapi-generator-cli generate -i https://localhost:7069/swagger/v1/swagger.json -g typescript-fetch -o ./src/lib/api/generated",
